@model FilscusBySky.Web.Models.GrafiekViewModel
@{
    ViewData["Title"] = "Grafieken";
}

<h2>Grafieken</h2>

<div class="row mt-4">
    <div class="col-md-8 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Inkomsten vs Uitgaven (laatste 6 maanden)</h5>
                <canvas id="staafGrafiek"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Uitgaven per categorie</h5>
                <canvas id="taartGrafiek"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const maanden = @Json.Serialize(Model.Maanden);
        const inkomsten = @Json.Serialize(Model.Inkomsten);
        const uitgaven = @Json.Serialize(Model.Uitgaven);
        const categorieen = @Json.Serialize(Model.Categorieen);
        const uitPerCat = @Json.Serialize(Model.UitgavenPerCategorie);

        // Staafdiagram
        new Chart(document.getElementById('staafGrafiek'), {
            type: 'bar',
            data: {
                labels: maanden,
                datasets: [
                    {
                        label: 'Inkomsten',
                        data: inkomsten,
                        backgroundColor: 'rgba(21, 66, 115, 0.8)'
                    },
                    {
                        label: 'Uitgaven',
                        data: uitgaven,
                        backgroundColor: 'rgba(220, 53, 69, 0.8)'
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Taartdiagram
        new Chart(document.getElementById('taartGrafiek'), {
            type: 'doughnut',
            data: {
                labels: categorieen,
                datasets: [{
                    data: uitPerCat,
                    backgroundColor: [
                        '#154273', '#dc3545', '#ffc107',
                        '#28a745', '#17a2b8', '#6f42c1', '#fd7e14'
                    ]
                }]
            },
            options: { responsive: true }
        });
    </script>
}