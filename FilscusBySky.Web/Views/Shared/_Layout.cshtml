<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FilscusBySky</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FilscusBySky.Web.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Rijksoverheid stijl header met logo -->
    <div class="ro-header">
        <div class="container">
            <div class="ro-logo">
                <div class="ro-logo-balk"></div>
                <span class="ro-logo-tekst">FilscusBySky</span>
            </div>
        </div>
    </div>

    <!-- Navigatiebalk -->
    <nav class="ro-nav">
        <div class="container">
            <ul class="ro-nav-list">
                @if (User.Identity!.IsAuthenticated)
                {
                <li><a href="/Dashboard">Dashboard</a></li>
                <li><a href="/Rekening">Rekeningen</a></li>
                <li><a href="/Grafiek">Grafieken</a></li>
                <li><a href="/Domiciliatie">Domiciliaties</a></li>
                <li><a href="/Advies">AI-advies</a></li>
                <li class="ro-nav-right">
                    <form method="post" asp-controller="Account" asp-action="Logout" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ro-nav-logout">Uitloggen</button>
                    </form>
                </li>
                }
                else
                {
                <li class="ro-nav-right"><a href="/Account/Login">Inloggen</a></li>
                <li><a href="/Account/Register">Registreren</a></li>
                }
            </ul>
        </div>
    </nav>

    <!-- Pagina inhoud -->
    <div class="container ro-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="ro-footer">
        <div class="container">
            <p>
                &copy; 2026 FilscusBySky &nbsp;|&nbsp;
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>