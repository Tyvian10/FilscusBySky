@{
    ViewData["Title"] = "Wachtwoord vergeten";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Wachtwoord vergeten</h2>

        @if (TempData["Bericht"] != null)
        {
        <div class="alert alert-info">@TempData["Bericht"]</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label>E-mailadres</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Verstuur reset link</button>
            <a asp-action="Login" class="btn btn-outline-secondary ms-2">Terug</a>
        </form>
    </div>
</div>