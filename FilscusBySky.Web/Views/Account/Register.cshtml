@{
    ViewData["Title"] = "Registreren";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Registreren</h2>

        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label>Volledige naam</label>
                <input type="text" name="volledigeNaam" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>E-mailadres</label>
                <input type="email" name="email" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Wachtwoord</label>
                <input type="password" name="password" class="form-control" required />
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" name="isVisueleBeperking" class="form-check-input" />
                <label class="form-check-label">Ik heb een visuele beperking</label>
            </div>

            <button type="submit" class="btn btn-primary">Registreren</button>
            <a asp-action="Login" class="ms-3">Al een account? Inloggen</a>
        </form>
    </div>
</div>