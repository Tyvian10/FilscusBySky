@{
    ViewData["Title"] = "Domiciliatie toevoegen";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Domiciliatie toevoegen</h2>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label>Naam</label>
                <input type="text" name="naam" class="form-control"
                       placeholder="bv. Huur" required />
            </div>

            <div class="mb-3">
                <label>Bedrag (€)</label>
                <input type="number" name="bedrag" class="form-control"
                       step="0.01" min="0.01" required />
            </div>

            <div class="mb-3">
                <label>Categorie</label>
                <select name="categorie" class="form-select">
                    <option>Huur</option>
                    <option>Verzekering</option>
                    <option>Abonnement</option>
                    <option>Transport</option>
                    <option>Gezondheid</option>
                    <option>Overig</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Dag van de maand</label>
                <input type="number" name="dag" class="form-control"
                       min="1" max="28" value="1" required />
            </div>

            <div class="mb-3">
                <label>Rekening</label>
                <select name="rekeningId" class="form-select">
                    @foreach (var rekening in ViewBag.Rekeningen)
                    {
                    <option value="@rekening.Id">@rekening.Naam</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Toevoegen</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Annuleren</a>
        </form>
    </div>
</div>