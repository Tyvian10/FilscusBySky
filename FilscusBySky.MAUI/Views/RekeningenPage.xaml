<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FilscusBySky.MAUI.Views.RekeningenPage"
             Title="Mijn Rekeningen">
    <ContentPage.Content>
        <StackLayout Padding="16">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#154273" />
            <CollectionView ItemsSource="{Binding Rekeningen}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,8" Padding="16"
                               BorderColor="#154273" CornerRadius="0">
                            <StackLayout>
                                <Label Text="{Binding Naam}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#154273" />
                                <Label Text="{Binding Saldo}"
                                       FontSize="16"
                                       TextColor="#333" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>